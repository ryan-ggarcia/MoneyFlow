<!-- Barra superior -->
<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-4 md:px-margin h-16 bg-surface">
  <div class="flex items-center gap-sm">
    <div class="icon-circle w-10 h-10 bg-surface-variant text-on-surface-variant overflow-hidden cursor-pointer transition-transform active:scale-90">
      <span class="material-symbols-outlined">person</span>
    </div>
    <span class="text-headline-md font-bold text-secondary">moneyFlow</span>
  </div>
  <button class="material-symbols-outlined text-primary p-2 rounded-full hover:opacity-80 transition-opacity active:scale-90" type="button" aria-label="Notificações">notifications</button>
</header>

<main class="mt-20 pb-32 px-4 md:px-margin max-w-[1280px] mx-auto">
  <!-- Saldo total -->
  <section class="mb-lg">
    <div class="card relative overflow-hidden group">
      <div class="absolute -right-12 -top-12 w-48 h-48 bg-secondary/10 rounded-full blur-3xl group-hover:bg-secondary/20 transition-all duration-500"></div>
      <p class="text-label-lg text-on-surface-variant mb-xs">Saldo Total</p>
      <h1 class="text-number-display text-secondary">R$ 12.850,00</h1>
      <div class="mt-sm flex items-center gap-xs text-primary-container">
        <span class="material-symbols-outlined text-sm">trending_up</span>
        <span class="text-label-md">+4,2% este mês</span>
      </div>
    </div>
  </section>

  <!-- Resumo rápido (receitas x despesas) -->
  <section class="grid grid-cols-2 gap-gutter mb-lg">
    <div class="card shadow-lift">
      <div class="flex items-center gap-sm mb-base">
        <div class="icon-circle w-8 h-8 bg-primary-container/20 text-primary-container">
          <span class="material-symbols-outlined text-[18px]">arrow_downward</span>
        </div>
        <span class="text-label-lg text-on-surface-variant">Receitas</span>
      </div>
      <p class="text-headline-md text-primary-container">R$ 5.420,00</p>
    </div>
    <div class="card shadow-lift">
      <div class="flex items-center gap-sm mb-base">
        <div class="icon-circle w-8 h-8 bg-tertiary-container/20 text-tertiary">
          <span class="material-symbols-outlined text-[18px]">arrow_upward</span>
        </div>
        <span class="text-label-lg text-on-surface-variant">Despesas</span>
      </div>
      <p class="text-headline-md text-tertiary">R$ 2.150,00</p>
    </div>
  </section>

  <!-- Fluxo de caixa (gráfico de barras simples) -->
  <section class="mb-lg">
    <div class="card">
      <div class="flex justify-between items-center mb-md">
        <h2 class="text-headline-md text-on-surface">Fluxo de Caixa</h2>
        <span class="text-label-md text-on-surface-variant bg-surface-container px-sm py-xs rounded-full">Últimos 7 dias</span>
      </div>
      <div class="flex items-end justify-between h-40 gap-xs">
        <div class="chart-bar h-[40%]"><span class="chart-bar-label">Seg</span></div>
        <div class="chart-bar h-[65%]"><span class="chart-bar-label">Ter</span></div>
        <div class="chart-bar bg-secondary-container h-[85%]"><span class="chart-bar-label">Qua</span></div>
        <div class="chart-bar h-[55%]"><span class="chart-bar-label">Qui</span></div>
        <div class="chart-bar h-[70%]"><span class="chart-bar-label">Sex</span></div>
        <div class="chart-bar h-[30%]"><span class="chart-bar-label">Sáb</span></div>
        <div class="chart-bar h-[45%]"><span class="chart-bar-label">Dom</span></div>
      </div>
    </div>
  </section>

  <!-- Últimas transações -->
  <section>
    <div class="flex justify-between items-center mb-md px-base">
      <h2 class="text-headline-md text-on-surface">Últimas Transações</h2>
      <button class="link-accent text-label-lg" type="button">Ver tudo</button>
    </div>
    <div class="flex flex-col gap-sm">
      <div class="card shadow-lift flex items-center justify-between cursor-pointer">
        <div class="flex items-center gap-md">
          <div class="icon-circle w-12 h-12 bg-surface-container text-on-surface">
            <span class="material-symbols-outlined">shopping_cart</span>
          </div>
          <div>
            <p class="text-body-md text-on-surface font-semibold">Supermercado Silva</p>
            <p class="text-label-md text-on-surface-variant">Hoje, 14:32 • Alimentação</p>
          </div>
        </div>
        <p class="text-headline-md text-tertiary">- R$ 185,20</p>
      </div>
      <div class="card shadow-lift flex items-center justify-between cursor-pointer">
        <div class="flex items-center gap-md">
          <div class="icon-circle w-12 h-12 bg-surface-container text-on-surface">
            <span class="material-symbols-outlined">payments</span>
          </div>
          <div>
            <p class="text-body-md text-on-surface font-semibold">Salário Mensal</p>
            <p class="text-label-md text-on-surface-variant">Ontem, 09:00 • Renda</p>
          </div>
        </div>
        <p class="text-headline-md text-primary-container">+ R$ 4.500,00</p>
      </div>
      <div class="card shadow-lift flex items-center justify-between cursor-pointer">
        <div class="flex items-center gap-md">
          <div class="icon-circle w-12 h-12 bg-surface-container text-on-surface">
            <span class="material-symbols-outlined">directions_car</span>
          </div>
          <div>
            <p class="text-body-md text-on-surface font-semibold">Posto Shell</p>
            <p class="text-label-md text-on-surface-variant">Ontem, 18:15 • Transporte</p>
          </div>
        </div>
        <p class="text-headline-md text-tertiary">- R$ 240,00</p>
      </div>
    </div>
  </section>
</main>

<!-- Botão flutuante de nova transação -->
<button class="fixed bottom-24 right-margin w-16 h-16 bg-secondary text-on-secondary rounded-full flex items-center justify-center shadow-lg hover:scale-105 active:scale-95 transition-transform z-40" type="button" aria-label="Adicionar transação">
  <span class="material-symbols-outlined text-[32px]">add</span>
</button>


<script>
  // Animação de entrada das barras: começam em 0% e crescem até a altura
  // definida na classe h-[..%] de cada uma (limpar o style devolve a altura da classe)
  window.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.chart-bar').forEach((barra, i) => {
      barra.style.height = '0%';
      setTimeout(() => {
        barra.style.transition = 'height 0.8s cubic-bezier(0.34, 1.56, 0.64, 1)';
        barra.style.height = '';
      }, 100 + i * 100);
    });
  });
</script>
