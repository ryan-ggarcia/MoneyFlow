<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>moneyFlow</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.css">
    <script src="https://cdn.jsdelivr.net/npm/notyf@3/notyf.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.25/dist/sweetalert2.all.min.js"></script>
    <link rel="stylesheet" href="/assets/css/application.css">
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.26.25/dist/sweetalert2.min.css" rel="stylesheet">
  </head>
  <body class="bg-background text-on-surface min-h-screen">
    <%= yield %>
    <!-- Barra de navegação inferior (o item da página atual ganha destaque) -->
    <% ativo = 'text-secondary font-bold' %>
    <% preenchido = "font-variation-settings: 'FILL' 1;" %>
    <nav class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 py-3 bg-surface-container-lowest rounded-t-xl shadow-[0px_-4px_20px_rgba(52,58,64,0.08)]">
      <a class="nav-item <%= ativo if request.path_info == '/' %>" href="/">
        <span class="material-symbols-outlined" style="<%= preenchido if request.path_info == '/' %>">home</span>
        <span class="text-label-md">Início</span>
      </a>
      <a class="nav-item <%= ativo if request.path_info.start_with?('/contas') %>" href="/contas">
        <span class="material-symbols-outlined" style="<%= preenchido if request.path_info.start_with?('/contas') %>">account_balance_wallet</span>
        <span class="text-label-md">Contas</span>
      </a>
      <a class="nav-item <%= ativo if request.path_info.start_with?('/cartoes') %>" href="/cartoes">
        <span class="material-symbols-outlined" style="<%= preenchido if request.path_info.start_with?('/cartoes') %>">credit_card</span>
        <span class="text-label-md">Cartões</span>
      </a>
      <a class="nav-item" href="#">
        <span class="material-symbols-outlined">person</span>
        <span class="text-label-md">Perfil</span>
      </a>
    </nav>
  </body>
</html>
