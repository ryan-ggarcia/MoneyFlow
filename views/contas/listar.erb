<!-- Barra superior -->
<header class="fixed top-0 left-0 w-full z-50 flex justify-between items-center px-4 md:px-margin h-16 bg-surface">
  <span class="text-headline-md font-bold text-secondary">moneyFlow</span>
  <div class="flex items-center gap-4">
    <button class="material-symbols-outlined text-on-surface-variant hover:opacity-80 transition-opacity active:scale-90" type="button" aria-label="Notificações">notifications</button>
    <div class="icon-circle w-10 h-10 bg-surface-variant text-on-surface-variant border-2 border-primary cursor-pointer transition-transform active:scale-90">
      <span class="material-symbols-outlined">person</span>
    </div>
  </div>
</header>

<main class="mt-20 pb-32 px-4 md:px-margin max-w-[1280px] mx-auto">
  <!-- Título -->
  <div class="mb-md">
    <p class="text-label-lg text-secondary uppercase tracking-widest">Meus Ativos</p>
    <h2 class="text-headline-lg text-on-surface">Minhas Contas</h2>
  </div>

  <!-- No mobile empilha; no desktop (lg) Ações Rápidas vira uma barra lateral
       (1/3) e "Suas Contas" ocupa os 2/3 restantes. -->
  <div class="grid gap-md lg:grid-cols-3 lg:items-start">
    <!-- Ações Rápidas -->
    <section class="card lg:col-span-1 lg:sticky lg:top-24">
      <h3 class="text-headline-md text-on-surface mb-md">Ações Rápidas</h3>
      <div class="grid grid-cols-2 gap-4">
        <button class="flex flex-col items-center justify-center p-4 bg-surface-container-low rounded-xl border border-outline-variant/10 hover:border-secondary transition-all group" type="button">
          <div class="icon-circle w-12 h-12 bg-secondary-container mb-2 group-hover:scale-110 transition-transform">
            <span class="material-symbols-outlined text-on-secondary-container">swap_horiz</span>
          </div>
          <span class="text-label-lg text-center">Transferir</span>
        </button>
        <button class="flex flex-col items-center justify-center p-4 bg-surface-container-low rounded-xl border border-outline-variant/10 hover:border-primary transition-all group" type="button">
          <div class="icon-circle w-12 h-12 bg-primary-container mb-2 group-hover:scale-110 transition-transform">
            <span class="material-symbols-outlined text-white">payments</span>
          </div>
          <span class="text-label-lg text-center">Pagar</span>
        </button>
      </div>
      <a class="w-full mt-6 py-4 px-6 bg-secondary text-white text-label-lg rounded-xl flex items-center justify-center gap-2 shadow-lift active:scale-[0.98]" href="/contas/cadastrar">
        <span class="material-symbols-outlined">add_circle</span>
        Adicionar Conta
      </a>
    </section>

    <!-- Suas Contas -->
    <section class="lg:col-span-2">
      <h3 class="text-headline-md text-on-surface mb-md">Suas Contas</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-gutter">
        <!-- Card Contas -->
        <% if !@contas.empty? %>
          <% @contas.each do |c| %>
            <div class="card shadow-lift border-l-4 cursor-pointer" style="border-left-color: <%= c['con_cor'] %>">
              <div class="flex justify-between items-start mb-4">
                <div class="flex items-center gap-3 min-w-0">
                  <div class="w-10 h-10 rounded-lg flex items-center justify-center text-white font-bold shrink-0" style="background-color: <%= c['con_cor'] %>">Nu</div>
                  <div class="min-w-0">
                    <h4 class="text-body-lg font-bold text-on-surface truncate"><%= c['con_nome'] %></h4>
                    <p class="text-label-md text-on-surface-variant"> <%= c['con_tipo'] == 'CORRENTE' ? 'Conta Corrente' : 'Conta Poupança' %> </p>
                  </div>
                </div>
                <button
                  class="js-opcoes-conta material-symbols-outlined text-on-surface-variant shrink-0 cursor-pointer hover:opacity-80 transition-opacity active:scale-90"
                  type="button"
                  aria-label="Opções da conta"
                  data-id="<%= c['con_id'] %>"
                  data-nome="<%= c['con_nome'] %>"
                  data-tipo="<%= c['con_tipo'] %>"
                  data-saldo="<%= c['con_saldo'].to_f %>"
                  data-pix="<%= c['con_chave'] %>"
                  data-cor="<%= c['con_cor'] %>"
                >more_vert</button>
              </div>
              <div class="mt-md">
                <p class="text-label-md text-on-surface-variant">Saldo Atual</p>
                <p class="text-headline-md text-primary-container">R$ <%= c['con_saldo'].to_f %> </p>
              </div>
            </div>
          <% end %>
        <% else %>
          <div>
            <span>Erro...</span>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</main>

<!-- Botão flutuante (só no mobile; no desktop o "Adicionar Conta" já aparece em Ações Rápidas) -->
<a class="fixed bottom-24 right-6 w-14 h-14 bg-secondary text-white rounded-full shadow-lg flex items-center justify-center lg:hidden transition-transform active:scale-90 z-40" href="/contas/cadastrar" aria-label="Adicionar Conta">
  <span class="material-symbols-outlined">add</span>
</a>

<div class="sheet-backdrop" id="conta-backdrop"></div>

<section class="bottom-sheet" id="conta-sheet" role="dialog" aria-modal="true" aria-labelledby="sheet-titulo" aria-hidden="true">
  <!-- Alcinha (só enfeite, sinaliza que dá pra fechar) -->
  <div class="sheet-handle"></div>

  <!-- Cabeçalho -->
  <div class="flex items-center justify-between px-md pb-sm shrink-0">
    <h3 class="text-headline-md text-on-surface" id="sheet-titulo">Editar conta</h3>
    <button class="material-symbols-outlined text-on-surface-variant hover:opacity-80 transition-opacity active:scale-90 cursor-pointer" type="button" id="conta-fechar" aria-label="Fechar">close</button>
  </div>

  <!-- Corpo rolável com os campos -->
  <form class="flex flex-col gap-gutter px-md pb-md overflow-y-auto flex-1" id="form-editar-conta">
    <!-- Guarda o id da conta que está sendo editada (o JS preenche) -->
    <input type="hidden" id="edit-id" name="id">

    <!-- Nome -->
    <div class="flex flex-col gap-base">
      <label class="field-label" for="edit-nome">Nome da Instituição</label>
      <div class="relative">
        <span class="material-symbols-outlined input-icon">account_balance</span>
        <input class="input-field" id="edit-nome" name="nome" maxlength="30" placeholder="Ex: Nubank, Itaú..." type="text">
      </div>
    </div>

    <!-- Tipo de conta -->
    <div class="flex flex-col gap-base">
      <label class="field-label" for="edit-tipo">Tipo de Conta</label>
      <div class="relative">
        <span class="material-symbols-outlined input-icon">category</span>
        <select class="input-field pr-12 appearance-none" id="edit-tipo" name="tipo">
          <option value="CORRENTE">Conta Corrente</option>
          <option value="POUPANCA">Poupança</option>
        </select>
        <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-outline pointer-events-none">expand_more</span>
      </div>
    </div>

    <!-- Saldo -->
    <div class="flex flex-col gap-base">
      <label class="field-label" for="edit-saldo">Saldo</label>
      <div class="relative">
        <span class="absolute left-4 top-1/2 -translate-y-1/2 font-bold text-outline">R$</span>
        <input class="input-field" id="edit-saldo" name="saldo" placeholder="0,00" type="number" step="0.01" min="0">
      </div>
    </div>

    <!-- Chave pix -->
    <div class="flex flex-col gap-base">
      <label class="field-label" for="edit-pix">Chave pix</label>
      <div class="relative">
        <span class="material-symbols-outlined input-icon">key</span>
        <input class="input-field" id="edit-pix" name="pix" placeholder="Cpf, número, email..." type="text">
      </div>
    </div>

    <!-- Identidade visual (cor da conta) — o JS marca a bolinha da cor atual ao abrir -->
    <div class="flex flex-col gap-base">
      <span class="field-label">Identidade Visual</span>
      <div class="flex justify-between items-center bg-surface-container p-3 rounded-lg">
        <div class="flex gap-3">
          <button class="js-edit-cor w-8 h-8 rounded-full bg-primary-container border-2 border-white shadow-sm" data-cor="#10b981" type="button" aria-label="Verde"></button>
          <button class="js-edit-cor w-8 h-8 rounded-full bg-secondary-container border-2 border-white shadow-sm" data-cor="#d4af37" type="button" aria-label="Dourado"></button>
          <button class="js-edit-cor w-8 h-8 rounded-full bg-tertiary-container border-2 border-white shadow-sm" data-cor="#a83639" type="button" aria-label="Vermelho"></button>
          <button class="js-edit-cor w-8 h-8 rounded-full bg-on-surface-variant border-2 border-white shadow-sm" data-cor="#3c4a42" type="button" aria-label="Grafite"></button>
          <button class="js-edit-cor w-8 h-8 rounded-full bg-blue-500 border-2 border-white shadow-sm" data-cor="#4a90e2" type="button" aria-label="Azul"></button>
        </div>
        <span class="material-symbols-outlined text-outline">palette</span>
      </div>
      <input type="hidden" id="edit-cor" name="cor" value="#10b981">
    </div>

    <!-- Ações: salvar alteração e excluir.
         No mobile o Salvar preenche a largura (flex-1); no desktop (lg:) ele
         para de esticar (lg:flex-none) e o par de botões alinha à direita. -->
    <div class="flex gap-sm pt-1 lg:justify-end">
      <button class="flex-1 lg:flex-none lg:px-10 py-4 bg-secondary text-on-secondary font-bold rounded-xl shadow-lift flex items-center justify-center gap-2" id="btn-salvar-edicao" type="submit">
        <span class="material-symbols-outlined">save</span>
        Salvar
      </button>
      <button class="py-4 px-6 bg-tertiary text-white font-bold rounded-xl shadow-lift flex items-center justify-center gap-2" id="btn-excluir-conta" type="button">
        <span class="material-symbols-outlined">delete</span>
        Excluir
      </button>
    </div>
  </form>
</section>

<script>
  (function () {
    const backdrop  = document.getElementById('conta-backdrop');
    const sheet     = document.getElementById('conta-sheet');
    const bolhasCor = document.querySelectorAll('.js-edit-cor');

    // Marca a bolinha da cor escolhida (ring) e guarda o valor no #edit-cor escondido
    function marcarCor(cor) {
      document.getElementById('edit-cor').value = cor || '';
      bolhasCor.forEach(function (b) {
        const selecionada = b.dataset.cor === cor;
        b.classList.toggle('ring-2', selecionada);
        b.classList.toggle('ring-secondary', selecionada);
      });
    }

    // Abre a folha e joga os dados do card clicado (data-*) nos campos
    function abrir(dados) {
      document.getElementById('edit-id').value    = dados.id    || '';
      document.getElementById('edit-nome').value  = dados.nome  || '';
      document.getElementById('edit-tipo').value  = dados.tipo  || 'CORRENTE';
      document.getElementById('edit-saldo').value = dados.saldo || '';
      document.getElementById('edit-pix').value   = dados.pix   || '';
      marcarCor(dados.cor || '#10b981');
      backdrop.classList.add('is-open');
      sheet.classList.add('is-open');
      sheet.setAttribute('aria-hidden', 'false');
    }

    function fechar() {
      backdrop.classList.remove('is-open');
      sheet.classList.remove('is-open');
      sheet.setAttribute('aria-hidden', 'true');
    }

    // Cada botão de três pontinhos carrega os dados da conta em data-*
    document.querySelectorAll('.js-opcoes-conta').forEach(function (botao) {
      botao.addEventListener('click', function (e) {
        e.stopPropagation(); // não deixa o clique "vazar" pro card
        abrir(botao.dataset);
      });
    });

    // Troca a cor ao clicar numa bolinha do modal
    bolhasCor.forEach(function (bolha) {
      bolha.addEventListener('click', function () {
        marcarCor(bolha.dataset.cor);
      });
    });

    // Fecha ao clicar no X, no fundo escuro ou apertar Esc
    document.getElementById('conta-fechar').addEventListener('click', fechar);
    backdrop.addEventListener('click', fechar);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') fechar();
    });
  })();
</script>
